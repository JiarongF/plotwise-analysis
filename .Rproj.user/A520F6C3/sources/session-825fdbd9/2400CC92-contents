pretty_table <- function(x, digits = 3, caption = NULL) {
  x_display <- x |>
    select(-any_of(c("estimate_value", "lower_value", "upper_value", "p_value_numeric")))

  out <- knitr::kable(
    x_display,
    digits = digits,
    caption = caption,
    format = "html"
  )

  if (requireNamespace("kableExtra", quietly = TRUE)) {
    out <- out |>
      kableExtra::kable_styling(
        full_width = FALSE,
        bootstrap_options = c("striped", "hover", "condensed")
      )
  }

  cat("\n", as.character(out), "\n")
  invisible(out)
}

fmt_p <- function(p) {
  case_when(
    is.na(p) ~ "NA",
    p < .001 ~ "< .001",
    TRUE ~ paste0("= ", signif(p, 3))
  )
}

fmt_pct <- function(x, accuracy = 1) {
  scales::percent(x, accuracy = accuracy)
}

make_group_labels <- function(x) {
  recode(
    as.character(x),
    CC = "CC: Control lecture + Control practice",
    CP = "CP: Control lecture + PlotWise practice",
    PC = "PC: PlotWise lecture + Control practice",
    PP = "PP: PlotWise lecture + PlotWise practice",
    .default = as.character(x)
  )
}

model_fixed_effect_table <- function(model) {
  out <- tryCatch(
    {
      coef_mat <- coef(summary(model))
      coef_df <- as.data.frame(coef_mat, check.names = FALSE) |>
        rownames_to_column("term") |>
        as_tibble()

      stat_col <- case_when(
        "z value" %in% names(coef_df) ~ "z value",
        "t value" %in% names(coef_df) ~ "t value",
        TRUE ~ NA_character_
      )

      p_col <- case_when(
        "Pr(>|z|)" %in% names(coef_df) ~ "Pr(>|z|)",
        "Pr(>|t|)" %in% names(coef_df) ~ "Pr(>|t|)",
        TRUE ~ NA_character_
      )

      coef_df2 <- coef_df |>
        mutate(
          statistic = if (!is.na(stat_col)) .data[[stat_col]] else NA_real_,
          p_value = case_when(
            !is.na(p_col) ~ as.numeric(.data[[p_col]]),
            !is.na(stat_col) ~ 2 * stats::pnorm(abs(.data[[stat_col]]), lower.tail = FALSE),
            TRUE ~ NA_real_
          )
        )

      coef_df2 |>
        transmute(
          Term = recode(
            term,
            `(Intercept)` = "Intercept",
            `lecture_typePlotWise` = "PlotWise lecture",
            `practice_typePlotWise` = "PlotWise practice",
            `lecture_typePlotWise:practice_typePlotWise` = "PlotWise lecture × PlotWise practice",
            `correlation_score_z` = "Correlation prior knowledge (standardized)",
            `slope_score_z` = "Slope prior knowledge (standardized)",
            `prior_knowledge_total_z` = "Total prior knowledge (standardized)",
            .default = term
          ),
          Estimate = round(Estimate, 3),
          SE = round(`Std. Error`, 3),
          `Test statistic` = round(statistic, 3),
          `p-value` = fmt_p(p_value)
        )
    },
    error = function(e) {
      tibble(
        Term = "Fixed-effect table unavailable",
        Estimate = NA_real_,
        SE = NA_real_,
        `Test statistic` = NA_real_,
        `p-value` = conditionMessage(e)
      )
    }
  )

  out
}

condition_estimates <- function(model, outcome_label, type = NULL) {
  emm <- emmeans(model, ~ lecture_type * practice_type)
  s <- if (is.null(type)) {
    as_tibble(summary(emm, infer = TRUE))
  } else {
    as_tibble(summary(emm, infer = TRUE, type = type))
  }

  estimate_col <- case_when(
    "response" %in% names(s) ~ "response",
    "emmean" %in% names(s) ~ "emmean",
    TRUE ~ NA_character_
  )

  lower_col <- case_when(
    "asymp.LCL" %in% names(s) ~ "asymp.LCL",
    "lower.CL" %in% names(s) ~ "lower.CL",
    TRUE ~ NA_character_
  )

  upper_col <- case_when(
    "asymp.UCL" %in% names(s) ~ "asymp.UCL",
    "upper.CL" %in% names(s) ~ "upper.CL",
    TRUE ~ NA_character_
  )

  s |>
    mutate(
      group = case_when(
        lecture_type == "Control" & practice_type == "Control" ~ "CC",
        lecture_type == "Control" & practice_type == "PlotWise" ~ "CP",
        lecture_type == "PlotWise" & practice_type == "Control" ~ "PC",
        lecture_type == "PlotWise" & practice_type == "PlotWise" ~ "PP",
        TRUE ~ NA_character_
      ),
      group = factor(group, levels = GROUP_LEVELS),
      estimate_value = .data[[estimate_col]],
      lower_value = .data[[lower_col]],
      upper_value = .data[[upper_col]]
    ) |>
    transmute(
      Outcome = outcome_label,
      Condition = group,
      `Estimated mean` = round(estimate_value, 3),
      `Lower 95% CI` = round(lower_value, 3),
      `Upper 95% CI` = round(upper_value, 3),
      estimate_value,
      lower_value,
      upper_value
    ) |>
    arrange(Condition)
}

clean_emm_comparison_table <- function(contrast_obj) {
  out <- as_tibble(summary(contrast_obj, infer = TRUE))

  estimate_col <- case_when(
    "estimate" %in% names(out) ~ "estimate",
    "odds.ratio" %in% names(out) ~ "odds.ratio",
    TRUE ~ NA_character_
  )

  lower_col <- case_when(
    "lower.CL" %in% names(out) ~ "lower.CL",
    "asymp.LCL" %in% names(out) ~ "asymp.LCL",
    TRUE ~ NA_character_
  )

  upper_col <- case_when(
    "upper.CL" %in% names(out) ~ "upper.CL",
    "asymp.UCL" %in% names(out) ~ "asymp.UCL",
    TRUE ~ NA_character_
  )

  p_col <- case_when(
    "p.value" %in% names(out) ~ "p.value",
    TRUE ~ NA_character_
  )

  out |>
    mutate(
      estimate_value = .data[[estimate_col]],
      lower_value = .data[[lower_col]],
      upper_value = .data[[upper_col]],
      p_value_numeric = .data[[p_col]]
    ) |>
    transmute(
      Contrast = contrast,
      Difference = round(estimate_value, 3),
      `Lower 95% CI` = round(lower_value, 3),
      `Upper 95% CI` = round(upper_value, 3),
      `p-value` = fmt_p(p_value_numeric),
      estimate_value,
      lower_value,
      upper_value,
      p_value_numeric
    )
}

plot_condition_estimates <- function(est_df, y_label, title, subtitle = NULL) {
  ggplot(est_df, aes(x = Condition, y = estimate_value, color = Condition)) +
    geom_pointrange(aes(ymin = lower_value, ymax = upper_value), linewidth = 0.8, size = 0.8) +
    scale_color_manual(values = GROUP_COLORS, guide = "none") +
    labs(title = title, subtitle = subtitle, x = "Condition", y = y_label) +
    theme(
      plot.title = element_text(face = "bold"),
      plot.subtitle = element_text(color = "gray35")
    )
}

plot_participant_with_model <- function(participant_df, estimate_df, y_col, y_label, title, subtitle = NULL) {
