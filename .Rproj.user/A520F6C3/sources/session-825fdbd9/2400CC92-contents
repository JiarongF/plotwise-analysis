# Condition contrasts

The model coefficients are relative to the reference condition, so I use contrasts to read the condition differences more directly. For value estimation, positive differences mean the first condition has **higher error** than the second condition. Since lower error is better, positive differences favor the second condition.

## Pairwise contrasts

```{r pairwise-contrasts}
emm_corr_group <- emmeans(m_corr, ~ lecture_type * practice_type)
emm_slope_group <- emmeans(m_slope, ~ lecture_type * practice_type)

pairwise_corr <- pairs(emm_corr_group, adjust = "tukey") |>
  clean_emm_comparison_table() |>
  mutate(Outcome = "Correlation") |>
  select(Outcome, everything())

pairwise_slope <- pairs(emm_slope_group, adjust = "tukey") |>
  clean_emm_comparison_table() |>
  mutate(Outcome = "Slope") |>
  select(Outcome, everything())

pretty_table(pairwise_corr, caption = "Pairwise comparisons: correlation absolute error")
pretty_table(pairwise_slope, caption = "Pairwise comparisons: slope absolute error")
```

```{r pairwise-plot, fig.height=5.5}
pairwise_plot_df <- bind_rows(pairwise_corr, pairwise_slope) |>
  mutate(
    Outcome = factor(Outcome, levels = c("Correlation", "Slope")),
    Contrast = fct_rev(Contrast)
  )

ggplot(pairwise_plot_df, aes(x = estimate_value, y = Contrast)) +
  geom_vline(xintercept = 0, linetype = "dashed", alpha = 0.6) +
  geom_errorbarh(aes(xmin = lower_value, xmax = upper_value), height = 0) +
  geom_point(aes(shape = p_value_numeric < .05), size = 2.5) +
  facet_wrap(~ Outcome, scales = "free_x") +
  scale_shape_manual(values = c(`TRUE` = 16, `FALSE` = 1), guide = "none") +
  labs(
    title = "Pairwise condition differences in value-estimation error",
    subtitle = "Positive values mean the first condition had higher error. Open circles are non-significant.",
    x = "Difference in mean absolute error",
    y = NULL
  ) +
  theme(
    plot.title = element_text(face = "bold"),
    plot.subtitle = element_text(color = "gray35")
  )
```

# Prior knowledge adjustment

This section asks whether baseline definition knowledge helps explain value-estimation performance.

For the correlation-estimation model, I add the coded correlation-definition score. For the slope-estimation model, I add the coded slope-definition score. Scores are standardized before entering the models.

The coded prior-knowledge file is expected to live in the same derived-data folder as the value-estimation files. In this project, that file is currently `prior_knowledge_coding_sheet_coded.csv` in `data/derived/`. Because this Rmd is knitted from the `scripts/` folder, the code uses `data_derived_dir` instead of hard-coding `data/derived/`.

```{r prior-knowledge-load}
find_prior_knowledge_file <- function() {
  candidates <- c(
    "prior_knowledge_coding_sheet_coded.csv",
    "prior_knowledge_scores.csv",
    "prior_knowledge_coded.csv",
    "coded_prior_knowledge.csv",
    "prior_knowledge_participant_level.csv",
    "scored_prior_knowledge.csv"
  )

  # The prior-knowledge file should be in the same derived-data folder as the
  # value-estimation files. Since this Rmd lives in scripts/, data_derived_dir
  # should already point to ../data/derived via utils.R. Use that as the main
  # location, and keep a few fallbacks only for robustness.
  candidate_dirs <- unique(c(
    data_derived_dir,
    normalizePath(data_derived_dir, mustWork = FALSE),
    file.path("..", "data", "derived"),
    normalizePath(file.path("..", "data", "derived"), mustWork = FALSE),
    file.path("data", "derived"),
    normalizePath(file.path("data", "derived"), mustWork = FALSE)
  ))

  paths <- unique(as.vector(outer(candidate_dirs, candidates, file.path)))
  existing <- paths[file.exists(paths)]

  if (length(existing) == 0) {
    attr(existing, "checked_paths") <- paths
    return(NA_character_)
  }

  existing[1]
}

find_first_col <- function(df, candidates) {
  cols <- candidates[candidates %in% names(df)]
  if (length(cols) == 0) NA_character_ else cols[1]
}

prior_knowledge_path <- find_prior_knowledge_file()
prior_knowledge_available <- !is.na(prior_knowledge_path)

if (prior_knowledge_available) {
  prior_raw <- read_csv(prior_knowledge_path, show_col_types = FALSE)

  # The coded prior-knowledge sheet is currently in long format:
  # one row per participant × concept, with `concept` = correlation/slope
  # and `score` = 0 / 0.5 / 1. If a future file is already participant-level
  # wide, the fallback below still handles that format.
  if (all(c("participantId", "concept", "score") %in% names(prior_raw))) {
    prior_knowledge_scores <- prior_raw |>
      mutate(
        concept = stringr::str_to_lower(as.character(concept)),
        score = as.numeric(score)
      ) |>
      filter(concept %in% c("correlation", "slope")) |>
      group_by(participantId, concept) |>
      summarise(score = mean(score, na.rm = TRUE), .groups = "drop") |>
      tidyr::pivot_wider(
        names_from = concept,
        values_from = score,
        names_glue = "{concept}_score"
      ) |>
      mutate(
        prior_knowledge_total = correlation_score + slope_score,
        correlation_score_z = as.numeric(scale(correlation_score)),
        slope_score_z = as.numeric(scale(slope_score)),
        prior_knowledge_total_z = as.numeric(scale(prior_knowledge_total))
      )

    prior_knowledge_format_note <- "long coded sheet"
  } else {
    corr_col <- find_first_col(
      prior_raw,
      c("correlation_score", "prior_correlation_score", "correlation_prior_score", "corr_score", "correlation_definition_score", "correlation_coded_score", "correlation_definition_coded", "correlation_code", "correlation_coding", "corr_code")
    )

    slope_col <- find_first_col(
      prior_raw,
      c("slope_score", "prior_slope_score", "slope_prior_score", "slope_definition_score", "slope_coded_score", "slope_definition_coded", "slope_code", "slope_coding")
    )

    total_col <- find_first_col(
      prior_raw,
      c("prior_knowledge_total", "prior_knowledge_score", "total_prior_score", "total_score", "prior_total", "definition_total_score")
    )

    if (is.na(corr_col) || is.na(slope_col)) {
      prior_knowledge_available <- FALSE
      prior_knowledge_scores <- tibble()
      prior_knowledge_column_note <- paste(names(prior_raw), collapse = ", ")
    } else {
      prior_knowledge_scores <- prior_raw |>
        transmute(
          participantId,
          correlation_score = as.numeric(.data[[corr_col]]),
          slope_score = as.numeric(.data[[slope_col]]),
          prior_knowledge_total = if (!is.na(total_col)) {
            as.numeric(.data[[total_col]])
          } else {
            correlation_score + slope_score
          }
        ) |>
        mutate(
          correlation_score_z = as.numeric(scale(correlation_score)),
          slope_score_z = as.numeric(scale(slope_score)),
          prior_knowledge_total_z = as.numeric(scale(prior_knowledge_total))
        )

      prior_knowledge_format_note <- "participant-level score file"
    }
  }

  if (prior_knowledge_available) {
    value_item_with_prior <- value_item |>
      left_join(prior_knowledge_scores, by = "participantId")

    value_participant_with_prior <- value_participant |>
      left_join(prior_knowledge_scores, by = "participantId")
  }
}
