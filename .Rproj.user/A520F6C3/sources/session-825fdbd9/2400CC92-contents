    geom_jitter(
      data = participant_df,
      aes(x = group, y = .data[[y_col]], color = group),
      width = 0.12,
      alpha = 0.55,
      size = 1.8
    ) +
    geom_pointrange(
      data = estimate_df,
      aes(x = Condition, y = estimate_value, ymin = lower_value, ymax = upper_value),
      color = "black",
      linewidth = 0.9,
      size = 0.8
    ) +
    scale_color_manual(values = GROUP_COLORS, guide = "none") +
    labs(title = title, subtitle = subtitle, x = "Condition", y = y_label) +
    theme(
      plot.title = element_text(face = "bold"),
      plot.subtitle = element_text(color = "gray35")
    )
}
