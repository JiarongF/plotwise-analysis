)

QUESTION_LABELS <- c(
  "switch-question-response-a" = "Switch X/Y: correlation",
  "switch-question-response-b" = "Switch X/Y: slope",
  "q-same" = "How slope and correlation are the same",
  "q-different" = "How slope and correlation are different"
)

if (is.na(coded_text_file)) {
