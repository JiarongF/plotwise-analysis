```{r setup, message=FALSE, warning=FALSE, include=FALSE}
source("../utils/utils.R")

library(tidyverse)
library(knitr)
library(kableExtra)
library(emmeans)

knitr::opts_chunk$set(
  echo = FALSE,
  message = FALSE,
  warning = FALSE,
  fig.width = 8,
  fig.height = 5,
  dpi = 150,
  results = "asis"
)

theme_set(theme_plotwise())

GROUP_LEVELS <- c("CC", "CP", "PC", "PP")
GROUP_COLORS <- c(
  "CC" = "#CC79A7",
  "CP" = "#0072B2",
  "PC" = "#D55E00",
  "PP" = "#009E73"
)

find_first_file <- function(paths) {
  hit <- paths[file.exists(paths)]
  if (length(hit) == 0) return(NA_character_)
  hit[[1]]
}

find_first_dir <- function(paths) {
  hit <- paths[dir.exists(paths)]
  if (length(hit) == 0) return(NA_character_)
  hit[[1]]
}

pretty_table <- function(x, digits = 3) {
  x |>
    mutate(across(where(is.numeric), ~ round(.x, digits))) |>
    kable(format = "html", escape = FALSE) |>
    kable_styling(full_width = FALSE, bootstrap_options = c("striped", "hover", "condensed"))
}

fmt_p <- function(p) {
  case_when(
    is.na(p) ~ NA_character_,
    p < .001 ~ "&lt; .001",
    TRUE ~ formatC(p, format = "f", digits = 3)
  )
}

make_group_labels <- function(df) {
  df |>
    mutate(
      group = factor(group, levels = GROUP_LEVELS),
      lecture_type = factor(lecture_type, levels = c("Control", "PlotWise")),
      practice_type = factor(practice_type, levels = c("Control", "PlotWise"))
    )
}

mean_or_na <- function(x) {
  if (all(is.na(x))) return(NA_real_)
  mean(x, na.rm = TRUE)
}

model_table_lm <- function(model) {
  coef(summary(model)) |>
    as.data.frame() |>
    rownames_to_column("term") |>
    as_tibble() |>
    rename(
      estimate = Estimate,
      std_error = `Std. Error`,
      statistic = `t value`,
      p_value = `Pr(>|t|)`
    ) |>
    mutate(p_value = fmt_p(p_value))
}

condition_estimates_lm <- function(model) {
  # The models use lecture_type * practice_type, while group (CC/CP/PC/PP)
  # is a derived label. Estimate the four cells from the model terms, then
  # rebuild the condition label for display.
  as.data.frame(emmeans(model, ~ lecture_type * practice_type)) |>
    as_tibble() |>
    mutate(
      group = case_when(
        lecture_type == "Control" & practice_type == "Control" ~ "CC",
        lecture_type == "Control" & practice_type == "PlotWise" ~ "CP",
        lecture_type == "PlotWise" & practice_type == "Control" ~ "PC",
        lecture_type == "PlotWise" & practice_type == "PlotWise" ~ "PP",
        TRUE ~ NA_character_
      ),
      group = factor(group, levels = GROUP_LEVELS)
    ) |>
    rename(
      condition_mean = emmean,
      se = SE,
      lower_ci = lower.CL,
      upper_ci = upper.CL
    ) |>
    select(group, lecture_type, practice_type, condition_mean, se, lower_ci, upper_ci) |>
    arrange(group)
}

plot_condition_points <- function(df, y_var, y_label, title, subtitle = NULL) {
  y_sym <- rlang::ensym(y_var)

  summary_df <- df |>
    group_by(group) |>
    summarise(
      mean_score = mean(!!y_sym, na.rm = TRUE),
      se = sd(!!y_sym, na.rm = TRUE) / sqrt(sum(!is.na(!!y_sym))),
      lower_ci = mean_score - 1.96 * se,
      upper_ci = mean_score + 1.96 * se,
      .groups = "drop"
    ) |>
    mutate(group = factor(group, levels = GROUP_LEVELS))

  ggplot(df, aes(x = group, y = !!y_sym, color = group)) +
    geom_jitter(width = 0.12, alpha = 0.55, size = 1.9) +
    geom_pointrange(
      data = summary_df,
      aes(x = group, y = mean_score, ymin = lower_ci, ymax = upper_ci),
      inherit.aes = FALSE,
      color = "black",
      linewidth = 0.7,
      size = 0.8
    ) +
    scale_color_manual(values = GROUP_COLORS, drop = FALSE) +
    labs(
      title = title,
      subtitle = subtitle,
      x = "Condition",
      y = y_label
    ) +
    theme_bw(base_size = 13) +
    theme(legend.position = "none")
}
```

# Overview

This notebook analyzes the conceptual-question portion of the assessment. This section includes two forced-choice items and four open-ended text responses:

- **Choose-strongest-r items**: participants choose which scatterplot has the stronger correlation.
- **Switch X/Y questions**: participants explain what happens to correlation and slope when X and Y are swapped.
- **Same/different questions**: participants describe how slope and correlation are similar and different.

I treat these as a separate conceptual-question outcome family rather than combining them with value estimation or add-points performance. Value estimation and add-points are also assessment tasks, but they capture different kinds of understanding. Within this report, I treat the four open-ended responses as the primary conceptual outcome because they directly ask participants to articulate conceptual similarities and differences between slope and correlation. The two choose-strongest-r items are reported separately as a short recognition check.

