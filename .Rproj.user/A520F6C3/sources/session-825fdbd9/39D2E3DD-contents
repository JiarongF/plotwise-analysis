# Bootstrap uncertainty

The mixed models are useful for estimating condition patterns, but I also include participant-level bootstrap intervals because value-estimation error has a natural participant-level summary.

The bootstrap resamples participants within each condition. For each bootstrap sample, it recomputes condition mean error and condition differences. This does not create more information; it just gives a nonparametric sense of how stable the observed condition differences are.

```{r bootstrap-functions}
set.seed(20260603)
N_BOOT <- 5000

bootstrap_condition_means <- function(df, outcome_col = "mean_abs_error", n_boot = 5000) {
  groups <- levels(df$group)

  map_dfr(seq_len(n_boot), function(iter_id) {
    map_dfr(groups, function(g) {
      g_df <- df |>
        filter(group == g, !is.na(.data[[outcome_col]]))

      sampled <- g_df[sample(seq_len(nrow(g_df)), size = nrow(g_df), replace = TRUE), ]

      tibble(
        iter = iter_id,
        group = g,
        mean_error = mean(sampled[[outcome_col]], na.rm = TRUE)
      )
    })
  }) |>
    mutate(group = factor(group, levels = GROUP_LEVELS))
}

summarise_boot_means <- function(boot_df) {
  boot_df |>
    group_by(group) |>
    summarise(
      bootstrap_mean_error = mean(.data[["mean_error"]], na.rm = TRUE),
      lower_95 = quantile(.data[["mean_error"]], .025, na.rm = TRUE),
      upper_95 = quantile(.data[["mean_error"]], .975, na.rm = TRUE),
      .groups = "drop"
    ) |>
    arrange(group)
}

summarise_boot_differences <- function(boot_df) {
  wide <- boot_df |>
    pivot_wider(names_from = group, values_from = mean_error)

  pairs <- combn(GROUP_LEVELS, 2, simplify = FALSE)

  map_dfr(pairs, function(pair) {
    diff_vec <- wide[[pair[1]]] - wide[[pair[2]]]

    tibble(
      Contrast = paste(pair[1], "-", pair[2]),
      mean_difference = mean(diff_vec, na.rm = TRUE),
      lower_95 = quantile(diff_vec, .025, na.rm = TRUE),
      upper_95 = quantile(diff_vec, .975, na.rm = TRUE)
    )
  })
}
```

