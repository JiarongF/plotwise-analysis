# Stricter reached-negative-r scoring used only as a diagnostic check.
# In the earlier analysis, add-points-2 appears to have counted reaching a negative final r
# as the correct direction. The current primary scoring is task-goal based.
scored_add_points_item_level <- scored_add_points_item_level |>
  mutate(
    r_correct_direction_current = r_correct_direction,
