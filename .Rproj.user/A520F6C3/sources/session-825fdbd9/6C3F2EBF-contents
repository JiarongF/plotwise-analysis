pretty_table <- function(x, digits = 3, caption = NULL) {
  x_display <- x |>
    select(-any_of(c("estimate_value", "lower_value", "upper_value", "p_value_numeric")))

  out <- knitr::kable(
    x_display,
    digits = digits,
    caption = caption,
    format = "html"
  )

  if (requireNamespace("kableExtra", quietly = TRUE)) {
    out <- out |>
      kableExtra::kable_styling(
        full_width = FALSE,
        bootstrap_options = c("striped", "hover", "condensed")
      )
  }

  cat("\n", as.character(out), "\n")
  invisible(out)
}

fmt_pct <- function(x, accuracy = 1) {
  scales::percent(x, accuracy = accuracy)
}

fmt_num <- function(x, digits = 3) {
  ifelse(is.na(x), NA_character_, format(round(x, digits), nsmall = digits))
}

fmt_p <- function(p) {
  case_when(
    is.na(p) ~ "NA",
    p < .001 ~ "< .001",
    TRUE ~ paste0("= ", signif(p, 3))
  )
}

fmt_p_table <- function(p) {
  case_when(
    is.na(p) ~ "NA",
    p < .001 ~ "< .001",
    TRUE ~ as.character(signif(p, 3))
  )
}

get_interaction_p_value <- function(model) {
  coef_df <- as.data.frame(coef(summary(model)), check.names = FALSE)
  coef_df$term <- rownames(coef_df)
  interaction_row <- coef_df |>
    as_tibble() |>
    filter(str_detect(term, "lecture_typePlotWise:practice_typePlotWise"))

  p_col <- case_when(
    "Pr(>|z|)" %in% names(interaction_row) ~ "Pr(>|z|)",
    "Pr(>|t|)" %in% names(interaction_row) ~ "Pr(>|t|)",
    TRUE ~ NA_character_
  )

  if (nrow(interaction_row) == 0 || is.na(p_col)) {
    return(NA_real_)
  }

  as.numeric(interaction_row[[p_col]][1])
}

extract_lrt_interaction <- function(full_model, reduced_model) {
  comp <- anova(reduced_model, full_model, test = "Chisq") |>
    as.data.frame(check.names = FALSE)

  chisq_col <- dplyr::case_when(
    "Chisq" %in% names(comp) ~ "Chisq",
    "LRT" %in% names(comp) ~ "LRT",
    TRUE ~ NA_character_
  )

  df_col <- dplyr::case_when(
    "Chi Df" %in% names(comp) ~ "Chi Df",
    "Df" %in% names(comp) ~ "Df",
    "df" %in% names(comp) ~ "df",
    TRUE ~ NA_character_
  )

  p_col <- dplyr::case_when(
    "Pr(>Chisq)" %in% names(comp) ~ "Pr(>Chisq)",
    "Pr(>Chi)" %in% names(comp) ~ "Pr(>Chi)",
    TRUE ~ NA_character_
  )

  tibble(
    comparison = "lecture type × practice type",
    chisq = if (!is.na(chisq_col)) comp[[chisq_col]][2] else NA_real_,
    df_num = if (!is.na(df_col)) comp[[df_col]][2] else NA_real_,
    p_value = if (!is.na(p_col)) comp[[p_col]][2] else NA_real_
  )
}

interaction_test_table <- function(test_df) {
  test_df |>
    transmute(
      Term = "Lecture type × practice type",
      `Likelihood-ratio χ²` = round(.data[["chisq"]], 3),
      df = .data[["df_num"]],
      `p-value` = fmt_p(.data[["p_value"]])
    )
}

