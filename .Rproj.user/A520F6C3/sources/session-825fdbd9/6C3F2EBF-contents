# 7. Modeling with Prior Knowledge

Participants differed in their baseline understanding of correlation and slope. This section adds prior knowledge as a covariate to check whether the condition pattern remains after accounting for baseline conceptual understanding.

For the correlation-direction outcomes, we use the coded **correlation definition score** as the covariate. For the slope-change outcome, we use the coded **slope definition score** as the covariate.

```{r prior-knowledge-load-functions}
find_prior_knowledge_file <- function() {
  candidates <- c(
    "prior_knowledge_scores.csv",
    "prior_knowledge_coded.csv",
    "coded_prior_knowledge.csv",
    "prior_knowledge_participant_level.csv",
    "scored_prior_knowledge.csv"
  )

  paths <- file.path(data_derived_dir, candidates)
  found <- paths[file.exists(paths)]

  if (length(found) == 0) return(NA_character_)
  found[1]
}

pick_col <- function(data, candidates) {
  nm <- names(data)
  hit <- candidates[candidates %in% nm]
  if (length(hit) == 0) return(NA_character_)
  hit[1]
}

prior_knowledge_path <- find_prior_knowledge_file()
prior_knowledge_available <- !is.na(prior_knowledge_path)

if (prior_knowledge_available) {
  prior_raw <- read_csv(prior_knowledge_path, show_col_types = FALSE)

  corr_col <- pick_col(
    prior_raw,
    c(
      "correlation_score",
      "corr_score",
      "correlation_definition_score",
      "prior_correlation_score",
      "correlation_prior_score"
    )
  )

  slope_col <- pick_col(
    prior_raw,
    c(
      "slope_score",
      "slope_definition_score",
      "prior_slope_score",
      "slope_prior_score"
    )
  )

  total_col <- pick_col(
    prior_raw,
    c(
      "prior_knowledge_total",
      "prior_knowledge_score",
      "total_prior_score",
      "total_score"
    )
  )

  if (is.na(corr_col) || is.na(slope_col)) {
    prior_knowledge_available <- FALSE
    prior_knowledge_scores <- tibble()
  } else {
    prior_knowledge_scores <- prior_raw |>
      transmute(
        participantId,
        correlation_score = as.numeric(.data[[corr_col]]),
        slope_score = as.numeric(.data[[slope_col]]),
        prior_knowledge_total = if (!is.na(total_col)) {
          as.numeric(.data[[total_col]])
        } else {
          correlation_score + slope_score
        }
      ) |>
      mutate(
        correlation_score_z = as.numeric(scale(correlation_score)),
        slope_score_z = as.numeric(scale(slope_score)),
        prior_knowledge_total_z = as.numeric(scale(prior_knowledge_total))
      )

    add_points_item_with_prior <- scored_add_points_item_level |>
      left_join(prior_knowledge_scores, by = "participantId")
  }
}
```

