}


model_lrt_table <- function(model) {
  out <- tryCatch(
    {
      d <- drop1(model, test = "Chisq") |>
        as.data.frame(check.names = FALSE) |>
        rownames_to_column("term") |>
        as_tibble() |>
        filter(term != "<none>")

      stat_col <- case_when(
        "LRT" %in% names(d) ~ "LRT",
        "Chisq" %in% names(d) ~ "Chisq",
        "Chi.sq" %in% names(d) ~ "Chi.sq",
        TRUE ~ NA_character_
      )

      df_col <- case_when(
        "Df" %in% names(d) ~ "Df",
        "Chi Df" %in% names(d) ~ "Chi Df",
        "npar" %in% names(d) ~ "npar",
        TRUE ~ NA_character_
      )

      p_col <- case_when(
        "Pr(Chi)" %in% names(d) ~ "Pr(Chi)",
        "Pr(>Chi)" %in% names(d) ~ "Pr(>Chi)",
        "Pr(>Chisq)" %in% names(d) ~ "Pr(>Chisq)",
        TRUE ~ NA_character_
      )

      d |>
        mutate(
          stat_value = if (!is.na(stat_col)) .data[[stat_col]] else NA_real_,
          df_value = if (!is.na(df_col)) .data[[df_col]] else NA_real_,
          p_value = if (!is.na(p_col)) .data[[p_col]] else NA_real_
        ) |>
        transmute(
          Term = recode(
            term,
            `lecture_type` = "Lecture type",
            `practice_type` = "Practice type",
            `lecture_type:practice_type` = "Lecture type × practice type",
            `task_goal` = "Task goal",
            `correlation_score` = "Correlation prior knowledge",
            `slope_score` = "Slope prior knowledge",
            `prior_knowledge_total` = "Total prior knowledge",
            `correlation_score_z` = "Correlation prior knowledge (standardized)",
            `slope_score_z` = "Slope prior knowledge (standardized)",
            `prior_knowledge_total_z` = "Total prior knowledge (standardized)",
            `correlation_score_z` = "Correlation prior knowledge (standardized)",
            `slope_score_z` = "Slope prior knowledge (standardized)",
            `prior_knowledge_total_z` = "Total prior knowledge (standardized)",
            .default = term
          ),
          `Likelihood-ratio χ²` = round(stat_value, 3),
          df = df_value,
          `p-value` = fmt_p(p_value)
        )
    },
    error = function(e) {
      tibble(
        Term = "Model term tests unavailable",
        `Likelihood-ratio χ²` = NA_real_,
        df = NA_real_,
        `p-value` = conditionMessage(e)
      )
    }
  )

  out
}

model_fixed_effect_table <- function(model) {
  out <- tryCatch(
    {
      coef_mat <- coef(summary(model))
      coef_df <- as.data.frame(coef_mat, check.names = FALSE) |>
        rownames_to_column("term") |>
        as_tibble()

      stat_col <- dplyr::case_when(
        "z value" %in% names(coef_df) ~ "z value",
        "t value" %in% names(coef_df) ~ "t value",
        TRUE ~ NA_character_
      )

      p_col <- dplyr::case_when(
        "Pr(>|z|)" %in% names(coef_df) ~ "Pr(>|z|)",
        "Pr(>|t|)" %in% names(coef_df) ~ "Pr(>|t|)",
        TRUE ~ NA_character_
      )

      coef_df2 <- coef_df |>
        mutate(
          statistic = if (!is.na(stat_col)) .data[[stat_col]] else NA_real_,
          p_value = dplyr::case_when(
            !is.na(p_col) ~ as.numeric(.data[[p_col]]),
            !is.na(stat_col) ~ 2 * stats::pnorm(abs(.data[[stat_col]]), lower.tail = FALSE),
            TRUE ~ NA_real_
          )
        )

      coef_df2 |>
        transmute(
          Term = recode(
            term,
            `(Intercept)` = "Intercept",
            `lecture_typePlotWise` = "PlotWise lecture",
            `practice_typePlotWise` = "PlotWise practice",
            `lecture_typePlotWise:practice_typePlotWise` = "PlotWise lecture × PlotWise practice",
            `correlation_score` = "Correlation prior knowledge",
            `slope_score` = "Slope prior knowledge",
            `prior_knowledge_total` = "Total prior knowledge",
            `correlation_score_z` = "Correlation prior knowledge (standardized)",
            `slope_score_z` = "Slope prior knowledge (standardized)",
            `prior_knowledge_total_z` = "Total prior knowledge (standardized)",
            .default = term
          ),
          Estimate = round(Estimate, 3),
          SE = round(`Std. Error`, 3),
          `Test statistic` = round(statistic, 3),
          `p-value` = fmt_p(p_value)
        )
    },
    error = function(e) {
      tibble(
        Term = "Fixed-effect table unavailable",
        Estimate = NA_real_,
        SE = NA_real_,
        `Test statistic` = NA_real_,
        `p-value` = conditionMessage(e)
      )
    }
  )

  out
}



model_full_results_table <- function(model) {
  model_fixed_effect_table(model)
}


clean_emm_comparison_table <- function(contrast_obj, type = NULL) {
  out <- if (is.null(type)) {
    as_tibble(summary(contrast_obj, infer = TRUE))
  } else {
    as_tibble(summary(contrast_obj, type = type, infer = TRUE))
  }

  estimate_col <- case_when(
    "odds.ratio" %in% names(out) ~ "odds.ratio",
    "ratio" %in% names(out) ~ "ratio",
    "estimate" %in% names(out) ~ "estimate",
    TRUE ~ NA_character_
  )

  lower_col <- case_when(
    "asymp.LCL" %in% names(out) ~ "asymp.LCL",
    "lower.CL" %in% names(out) ~ "lower.CL",
    TRUE ~ NA_character_
  )

  upper_col <- case_when(
    "asymp.UCL" %in% names(out) ~ "asymp.UCL",
    "upper.CL" %in% names(out) ~ "upper.CL",
    TRUE ~ NA_character_
  )

  stat_col <- case_when(
    "z.ratio" %in% names(out) ~ "z.ratio",
    "t.ratio" %in% names(out) ~ "t.ratio",
    TRUE ~ NA_character_
  )

  out |>
    mutate(
      estimate_value = if (!is.na(estimate_col)) .data[[estimate_col]] else NA_real_,
      lower_value = if (!is.na(lower_col)) .data[[lower_col]] else NA_real_,
      upper_value = if (!is.na(upper_col)) .data[[upper_col]] else NA_real_,
      statistic_value = if (!is.na(stat_col)) .data[[stat_col]] else NA_real_,
      estimate_label = case_when(
        estimate_col == "odds.ratio" ~ "Odds ratio",
        estimate_col == "ratio" ~ "Ratio",
        TRUE ~ "Difference"
      )
    ) |>
    transmute(
      Contrast = contrast,
      `Estimate type` = estimate_label,
      Estimate = round(estimate_value, 3),
      `95% CI` = ifelse(
        is.na(lower_value) | is.na(upper_value),
        "—",
        paste0(round(lower_value, 3), " to ", round(upper_value, 3))
      ),
      SE = round(SE, 3),
      `Test statistic` = round(statistic_value, 3),
      `p-value` = fmt_p_table(p.value),
      p_value_numeric = p.value,
      estimate_value = estimate_value,
      lower_value = lower_value,
      upper_value = upper_value
    )
}

plot_comparison_forest <- function(comparison_table, title, subtitle = NULL, null_value = 0) {
  plot_df <- comparison_table |>
    filter(!is.na(estimate_value)) |>
    mutate(
      Contrast = fct_rev(fct_inorder(Contrast)),
      significant = !is.na(p_value_numeric) & p_value_numeric < .05
    )

  ggplot(plot_df, aes(x = estimate_value, y = Contrast)) +
    geom_vline(xintercept = null_value, linewidth = 0.5, linetype = "dashed", color = "grey55") +
    geom_segment(
      aes(x = lower_value, xend = upper_value, y = Contrast, yend = Contrast),
      linewidth = 0.6,
      color = "grey35",
      na.rm = TRUE
    ) +
    geom_point(aes(shape = significant), size = 2.7, color = "#2F2F2F") +
    scale_shape_manual(values = c(`TRUE` = 16, `FALSE` = 1), guide = "none") +
    labs(
      title = title,
      subtitle = subtitle,
      x = ifelse(null_value == 1, "Odds ratio", "Estimated difference"),
      y = NULL
    ) +
    theme_minimal(base_size = 12) +
    theme(
      panel.grid.major.y = element_blank(),
      plot.title = element_text(face = "bold"),
      plot.subtitle = element_text(color = "grey35")
    )
}

