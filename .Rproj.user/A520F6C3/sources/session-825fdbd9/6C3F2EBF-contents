    `Current scoring correct` = fmt_pct(current_correct),
    `Reached-negative-r check correct` = fmt_pct(legacy_correct),
    `Rows changed by stricter check` = n_changed
  )

pretty_table(
  legacy_scoring_summary,
  caption = "Primary scoring vs. reached-negative-r check"
)
```

```{r legacy-correct-direction-model}
m_add_r_correct_legacy <- glmer(
  r_correct_direction_legacy_task2_negative ~ lecture_type * practice_type + (1 | participantId),
  data = scored_add_points_item_level,
  family = binomial
)

emm_add_r_correct_legacy <- emmeans(
