      TRUE ~ r_correct_direction_current
    ),
    scoring_changed_under_legacy = case_when(
      is.na(r_correct_direction_current) | is.na(r_correct_direction_legacy_task2_negative) ~ NA,
      TRUE ~ r_correct_direction_current != r_correct_direction_legacy_task2_negative
    )
  )
