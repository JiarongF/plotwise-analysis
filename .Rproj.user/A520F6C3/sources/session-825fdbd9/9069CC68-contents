```{r key-relationship-interpretation, results='asis'}
if (nrow(key_results) > 0) {
  cat('<div class="note-box"><strong>Interpretation: key relationships.</strong><br><br>')

  print_pair_interp <- function(x, y, label, interpretation) {
    row <- key_results |>
      filter((outcome_x == x & outcome_y == y) |
               (outcome_y == x & outcome_x == y)) |>
      slice_head(n = 1)

    if (nrow(row) == 1) {
      direction <- ifelse(row$estimate >= 0, "positive", "negative")
      cat(
        '<p><strong>', label, ':</strong> Spearman r = ', fmt_r(row$estimate),
        ', p = ', fmt_p(row$p_value), '. This is a ', row$strength_label,
        ' ', direction, ' association. ', interpretation, '</p>'
      )
    }
  }

  print_pair_interp(
    "prior_total",
    "open_response_score",
    "Prior knowledge and open response",
    "Participants with stronger incoming slope/correlation definitions also tended to write stronger open-ended conceptual responses. This means the open-response outcome is meaningfully related to baseline knowledge, which is why controlling for prior knowledge in the conceptual model is important."
  )

  print_pair_interp(
    "open_response_score",
    "add_points_correct_direction",
    "Open response and add-points",
    "The association is only weak. This suggests that being able to verbally explain slope/correlation concepts and being able to manipulate points in the intended direction may be related but separable skills."
  )

  print_pair_interp(
    "open_response_score",
    "value_estimation_performance",
    "Open response and value estimation",
    "This relationship indicates that conceptual explanation is more clearly aligned with numeric value-estimation performance than with the add-points manipulation outcome."
  )

  print_pair_interp(
    "value_estimation_performance",
    "add_points_correct_direction",
    "Value estimation and add-points",
    "This modest association suggests that numeric estimation and interactive manipulation overlap somewhat, but they are not interchangeable assessment outcomes."
  )

  print_pair_interp(
    "interest_future",
    "open_response_score",
    "Future interest and open response",
    "Participants who expressed greater future interest also tended to have stronger open-ended conceptual responses. This is exploratory, but it suggests that conceptual understanding and interest may move together."
  )

  print_pair_interp(
    "interest_future",
    "add_points_correct_direction",
    "Future interest and add-points",
    "This association is weaker than the future-interest/open-response relationship, suggesting that interest may be more closely aligned with conceptual explanation than with the interactive manipulation score."
  )

  cat(
    '<p><strong>Overall:</strong> the performance outcomes do not all collapse into one single construct. Prior knowledge, value estimation, and open-response explanation are meaningfully connected, while add-points slope preservation appears largely separate. This supports treating the outcome families separately in the main results.</p>',
    '</div>'
  )
}
