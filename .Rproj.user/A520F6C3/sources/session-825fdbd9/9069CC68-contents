  left_join(choose_participant, by = "participantId") |>
  left_join(interest_participant, by = "participantId")

candidate_outcome_vars <- c(
  "prior_total",
  "value_estimation_performance",
  "value_correlation_performance",
  "value_slope_performance",
  "add_points_correct_direction",
  "add_points_slope_preservation",
  "add_points_intended_delta_r",
  "open_response_score",
  "choose_r_pct_correct",
  "interest_triggered",
  "interest_maintained",
  "interest_future"
)

available_outcome_vars <- intersect(candidate_outcome_vars, names(outcome_family))
outcome_vars <- available_outcome_vars[
  map_lgl(available_outcome_vars, ~ any(!is.na(outcome_family[[.x]])))
]

# Remove duplicated or less central measures if both an overall and subscale version exist.
# Keep value_estimation_performance as the main value-estimation measure, but keep correlation/slope
# sub-measures available in the missingness table and optional checks.
main_correlation_vars <- intersect(
  c(
    "prior_total",
    "value_estimation_performance",
    "add_points_correct_direction",
    "add_points_slope_preservation",
    "open_response_score",
    "choose_r_pct_correct",
    "interest_triggered",
    "interest_maintained",
    "interest_future"
  ),
  outcome_vars
)

missingness_table <- tibble(outcome = outcome_vars) |>
  mutate(
    outcome_label = label_outcome(outcome),
    n_available = map_int(outcome, ~ sum(!is.na(outcome_family[[.x]]))),
    n_missing = nrow(outcome_family) - n_available,
    percent_available = n_available / nrow(outcome_family)
  ) |>
  select(outcome_label, n_available, n_missing, percent_available)

pretty_table(missingness_table, caption = "Participant-level outcome availability")

readr::write_csv(outcome_family, file.path(data_derived_dir, "outcome_family_participant_level.csv"))
