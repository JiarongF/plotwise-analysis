# 4. Key relationships

The full matrix is useful, but a few relationships are especially important for interpreting the study:

- **Prior knowledge ↔ open response:** whether open-ended conceptual explanation mostly reflects baseline knowledge.
- **Open response ↔ add-points:** whether verbal conceptual understanding maps onto interactive manipulation performance.
- **Value estimation ↔ add-points:** whether numeric estimation and interactive manipulation seem to be the same skill.
- **Interest ↔ performance:** whether participants who were more interested also performed better.

```{r key-relationship-table}
key_pairs <- tribble(
  ~outcome_x, ~outcome_y, ~why_it_matters,
  "prior_total", "open_response_score", "Does open-response performance reflect baseline prior knowledge?",
  "open_response_score", "add_points_correct_direction", "Does verbal conceptual understanding connect to interactive add-points performance?",
  "open_response_score", "value_estimation_performance", "Does conceptual explanation connect to numeric value-estimation performance?",
  "value_estimation_performance", "add_points_correct_direction", "Do numeric estimation and interactive manipulation capture the same skill?",
  "interest_future", "open_response_score", "Does future interest align with conceptual explanation?",
  "interest_future", "add_points_correct_direction", "Does future interest align with interactive task performance?"
) |>
  filter(outcome_x %in% main_correlation_vars, outcome_y %in% main_correlation_vars)

get_pair_result <- function(x, y) {
  direct <- cor_pairwise |>
    filter(outcome_x == x, outcome_y == y)

  reverse <- cor_pairwise |>
    filter(outcome_x == y, outcome_y == x) |>
    transmute(
      outcome_x = y,
      outcome_y = x,
      n,
      estimate,
      p_value,
      method,
      outcome_x_label = outcome_y_label,
      outcome_y_label = outcome_x_label,
      abs_estimate,
      p_value_display,
      estimate_display
    )

  bind_rows(direct, reverse) |>
    slice_head(n = 1)
}

key_results <- key_pairs |>
  mutate(result = map2(outcome_x, outcome_y, get_pair_result)) |>
  unnest(result) |>
  mutate(
    outcome_x_label = label_outcome(outcome_x),
    outcome_y_label = label_outcome(outcome_y),
    estimate_display = fmt_r(estimate),
    p_value_display = fmt_p(p_value),
    strength_label = case_when(
      is.na(abs(estimate)) ~ "not available",
      abs(estimate) >= .50 ~ "stronger",
      abs(estimate) >= .30 ~ "moderate",
      abs(estimate) >= .10 ~ "weak",
      TRUE ~ "very weak"
    )
  )

pretty_table(
  key_results |>
    transmute(
      `Outcome 1` = outcome_x_label,
      `Outcome 2` = outcome_y_label,
      n,
      `Spearman r` = estimate,
      `p-value` = p_value_display,
      `Why this matters` = why_it_matters
    ),
  caption = "Key cross-outcome relationships"
)
