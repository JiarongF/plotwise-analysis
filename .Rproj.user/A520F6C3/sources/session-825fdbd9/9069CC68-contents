## 1.1 Prior knowledge

```{r build-prior}
prior_raw <- read_csv_or_empty(prior_file)

if (nrow(prior_raw) > 0) {
  if (all(c("responseId", "score") %in% names(prior_raw))) {
    prior_participant <- prior_raw |>
      mutate(
        concept_tmp = if ("concept" %in% names(prior_raw)) as.character(concept) else NA_character_,
        prior_component = case_when(
          responseId %in% c("q-correlation", "correlation") ~ "correlation",
          responseId %in% c("q-slope", "slope") ~ "slope",
          str_detect(str_to_lower(concept_tmp), "correlation") ~ "correlation",
          str_detect(str_to_lower(concept_tmp), "slope") ~ "slope",
          TRUE ~ NA_character_
        )
      ) |>
      filter(!is.na(prior_component)) |>
      group_by(participantId, prior_component) |>
      summarise(score = mean(score, na.rm = TRUE), .groups = "drop") |>
      pivot_wider(
        names_from = prior_component,
        values_from = score,
        names_prefix = "prior_"
      ) |>
      mutate(
        prior_total = prior_correlation + prior_slope
      )
  } else {
    prior_corr_col <- first_existing_col(prior_raw, c("prior_correlation", "prior_correlation_score", "correlation_score"))
    prior_slope_col <- first_existing_col(prior_raw, c("prior_slope", "prior_slope_score", "slope_score"))
    prior_total_col <- first_existing_col(prior_raw, c("prior_total", "prior_knowledge_total", "prior_score"))

    prior_participant <- prior_raw |>
      transmute(
        participantId,
        prior_correlation = if (!is.na(prior_corr_col)) .data[[prior_corr_col]] else NA_real_,
        prior_slope = if (!is.na(prior_slope_col)) .data[[prior_slope_col]] else NA_real_,
        prior_total = if (!is.na(prior_total_col)) .data[[prior_total_col]] else prior_correlation + prior_slope
      ) |>
      distinct()
  }
} else {
  prior_participant <- tibble(participantId = character(), prior_correlation = numeric(), prior_slope = numeric(), prior_total = numeric())
}

prior_participant <- prior_participant |>
  select(participantId, prior_correlation, prior_slope, prior_total)

pretty_table(
  participant_index |>
    left_join(prior_participant, by = "participantId") |>
    group_by(group) |>
    summarise(
      n_with_prior = sum(!is.na(prior_total)),
      mean_prior_total = mean(prior_total, na.rm = TRUE),
      sd_prior_total = sd(prior_total, na.rm = TRUE),
      .groups = "drop"
    ),
  caption = "Prior knowledge by condition"
)
```

## 1.2 Value estimation

```{r build-value}
value_raw <- read_csv_or_empty(value_file)

if (nrow(value_raw) > 0) {
  value_error_col <- first_existing_col(value_raw, c("mean_abs_error", "median_abs_error", "abs_error"))

  if (!is.na(value_error_col) && "stat_type" %in% names(value_raw)) {
    value_participant <- value_raw |>
      mutate(
        stat_type = str_to_lower(as.character(stat_type)),
        value_error = .data[[value_error_col]]
      ) |>
      group_by(participantId) |>
      summarise(
        value_estimation_error = mean(value_error, na.rm = TRUE),
        value_correlation_error = mean(value_error[stat_type == "correlation"], na.rm = TRUE),
        value_slope_error = mean(value_error[stat_type == "slope"], na.rm = TRUE),
        .groups = "drop"
      ) |>
      mutate(
        value_estimation_performance = -value_estimation_error,
        value_correlation_performance = -value_correlation_error,
        value_slope_performance = -value_slope_error
      ) |>
      select(participantId, value_estimation_performance, value_correlation_performance, value_slope_performance)
  } else if (!is.na(value_error_col)) {
    value_participant <- value_raw |>
      group_by(participantId) |>
      summarise(value_estimation_performance = -mean(.data[[value_error_col]], na.rm = TRUE), .groups = "drop")
  } else {
    value_participant <- tibble(participantId = character(), value_estimation_performance = numeric())
  }
} else {
  value_participant <- tibble(participantId = character(), value_estimation_performance = numeric())
}

pretty_table(
  participant_index |>
    left_join(value_participant, by = "participantId") |>
    summarise(
      n_with_value_estimation = sum(!is.na(value_estimation_performance))
    ),
  caption = "Value-estimation data check"
)
