## 1.5 Interest

```{r build-interest}
interest_participant_raw <- read_csv_or_empty(interest_participant_file)
interest_item_raw <- read_csv_or_empty(interest_item_file)

clean_scale_type <- function(x) {
  case_when(
    str_detect(str_to_lower(as.character(x)), "trigger|tsi") ~ "triggered",
    str_detect(str_to_lower(as.character(x)), "maintain|msi") ~ "maintained",
    str_detect(str_to_lower(as.character(x)), "future") ~ "future",
    TRUE ~ as.character(x)
  )
}

if (nrow(interest_participant_raw) > 0) {
  if (all(c("participantId", "scale_type") %in% names(interest_participant_raw))) {
    score_col <- first_existing_col(interest_participant_raw, c("composite", "mean_score", "score", "interest_score"))

    interest_participant <- interest_participant_raw |>
      mutate(
        scale_clean = clean_scale_type(scale_type),
        score = if (!is.na(score_col)) .data[[score_col]] else NA_real_
      ) |>
      select(participantId, scale_clean, score) |>
      filter(scale_clean %in% c("triggered", "maintained", "future")) |>
      pivot_wider(names_from = scale_clean, values_from = score, names_prefix = "interest_")
  } else {
    triggered_col <- first_existing_col(interest_participant_raw, c("interest_triggered", "TSI", "triggered", "triggered_interest"))
    maintained_col <- first_existing_col(interest_participant_raw, c("interest_maintained", "MSI", "maintained", "maintained_interest"))
    future_col <- first_existing_col(interest_participant_raw, c("interest_future", "FutureInterest", "future", "future_interest"))

    interest_participant <- interest_participant_raw |>
      transmute(
        participantId,
        interest_triggered = if (!is.na(triggered_col)) .data[[triggered_col]] else NA_real_,
        interest_maintained = if (!is.na(maintained_col)) .data[[maintained_col]] else NA_real_,
        interest_future = if (!is.na(future_col)) .data[[future_col]] else NA_real_
      ) |>
      distinct()
  }
} else if (nrow(interest_item_raw) > 0 && all(c("participantId", "scale_type") %in% names(interest_item_raw))) {
  score_col <- first_existing_col(interest_item_raw, c("answer_scored", "score", "answer_num"))

  interest_participant <- interest_item_raw |>
    mutate(
      scale_clean = clean_scale_type(scale_type),
      score = if (!is.na(score_col)) .data[[score_col]] else NA_real_
    ) |>
    filter(scale_clean %in% c("triggered", "maintained", "future")) |>
    group_by(participantId, scale_clean) |>
    summarise(score = mean(score, na.rm = TRUE), .groups = "drop") |>
    pivot_wider(names_from = scale_clean, values_from = score, names_prefix = "interest_")
} else {
  interest_participant <- tibble(
    participantId = character(),
    interest_triggered = numeric(),
    interest_maintained = numeric(),
    interest_future = numeric()
  )
}

pretty_table(
  participant_index |>
    left_join(interest_participant, by = "participantId") |>
    summarise(
      n_with_triggered_interest = sum(!is.na(interest_triggered)),
      n_with_maintained_interest = sum(!is.na(interest_maintained)),
      n_with_future_interest = sum(!is.na(interest_future))
