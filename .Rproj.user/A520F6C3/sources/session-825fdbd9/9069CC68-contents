plot_pair <- function(df, x_var, y_var, title, x_label = NULL, y_label = NULL) {
  if (!all(c(x_var, y_var) %in% names(df))) return(NULL)

  d <- df |>
    filter(!is.na(.data[[x_var]]), !is.na(.data[[y_var]]))

  if (nrow(d) < 3) return(NULL)

  ggplot(d, aes(x = .data[[x_var]], y = .data[[y_var]], color = group)) +
    geom_point(size = 2.2, alpha = 0.75) +
    geom_smooth(method = "lm", se = TRUE, color = "black", linewidth = 0.7) +
    scale_color_manual(values = GROUP_COLORS, drop = FALSE) +
    labs(
