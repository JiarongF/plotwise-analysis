label_outcome <- function(x) {
  recode(
    x,
    prior_total = "Prior knowledge total",
    value_estimation_performance = "Value estimation performance",
    value_correlation_performance = "Correlation estimation performance",
    value_slope_performance = "Slope estimation performance",
    add_points_correct_direction = "Add-points correct direction",
    add_points_slope_preservation = "Add-points slope preservation",
    add_points_intended_delta_r = "Add-points intended Δr",
    open_response_score = "Open-response conceptual score",
    open_response_mean = "Open-response mean score",
    choose_r_pct_correct = "Choose-r accuracy",
    interest_triggered = "Triggered situational interest",
    interest_maintained = "Maintained situational interest",
    interest_future = "Future interest",
    .default = x
  )
}

calc_pairwise_cor <- function(df, vars, method = "spearman") {
  pairs <- combn(vars, 2, simplify = FALSE)

  map_dfr(pairs, function(pair) {
    x_name <- pair[[1]]
    y_name <- pair[[2]]

    d <- df |>
      select(all_of(c(x_name, y_name))) |>
      filter(!is.na(.data[[x_name]]), !is.na(.data[[y_name]]))

    if (nrow(d) < 3) {
      return(tibble(
        outcome_x = x_name,
        outcome_y = y_name,
        n = nrow(d),
        estimate = NA_real_,
        p_value = NA_real_,
        method = method
      ))
    }

    test <- suppressWarnings(
      cor.test(
        d[[x_name]],
        d[[y_name]],
        method = method,
        exact = FALSE
      )
    )

    tibble(
      outcome_x = x_name,
      outcome_y = y_name,
      n = nrow(d),
      estimate = unname(test$estimate),
      p_value = test$p.value,
      method = method
    )
  })
}

make_correlation_matrix <- function(pairwise_df, vars) {
  diag_df <- tibble(
    outcome_x = vars,
    outcome_y = vars,
    estimate = 1
  )

  mirrored <- pairwise_df |>
    select(outcome_x, outcome_y, estimate) |>
    bind_rows(
      pairwise_df |>
        transmute(outcome_x = outcome_y, outcome_y = outcome_x, estimate = estimate)
    ) |>
    bind_rows(diag_df) |>
    mutate(
      outcome_x = factor(outcome_x, levels = vars),
      outcome_y = factor(outcome_y, levels = rev(vars)),
      outcome_x_label = factor(label_outcome(as.character(outcome_x)), levels = label_outcome(vars)),
      outcome_y_label = factor(label_outcome(as.character(outcome_y)), levels = rev(label_outcome(vars)))
    )

  mirrored
}
