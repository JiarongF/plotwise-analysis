select(condition, n_participants),
caption = "Participants per condition"
)
add_points_participant_summary <- scored_add_points_participant_level |>
mutate(
n_correct_direction = round(add_points_pct_r_correct * add_points_n_items)
) |>
group_by(group, lecture_type, practice_type) |>
summarise(
n_participants = n(),
mean_correct_out_of_3 = mean(n_correct_direction, na.rm = TRUE),
sd_correct_out_of_3 = sd(n_correct_direction, na.rm = TRUE),
mean_pct_correct = mean(add_points_pct_r_correct, na.rm = TRUE),
sd_pct_correct = sd(add_points_pct_r_correct, na.rm = TRUE),
mean_intended_delta_r = mean(add_points_mean_intended_delta_r, na.rm = TRUE),
sd_intended_delta_r = sd(add_points_mean_intended_delta_r, na.rm = TRUE),
mean_abs_delta_slope = mean(add_points_mean_abs_delta_slope, na.rm = TRUE),
sd_abs_delta_slope = sd(add_points_mean_abs_delta_slope, na.rm = TRUE),
mean_reached_negative_r = mean(add_points_pct_reached_negative_r, na.rm = TRUE),
.groups = "drop"
) |>
arrange(group)
summary_display <- add_points_participant_summary |>
transmute(
condition = make_group_labels(group),
n = n_participants,
`Correct direction, M out of 3` = round(mean_correct_out_of_3, 2),
`Correct direction, %` = fmt_pct(mean_pct_correct),
`Intended Δr, M` = round(mean_intended_delta_r, 3),
`|Δ slope|, M` = round(mean_abs_delta_slope, 3),
