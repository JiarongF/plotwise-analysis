practice_type = factor(practice_type, levels = c("Control", "PlotWise")),
group = factor(group, levels = GROUP_LEVELS),
task_goal = factor(
task_goal,
levels = c(
"Increase positive correlation",
"Increase negative correlation",
"Move correlation closer to zero"
)
)
)
