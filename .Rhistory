)
pretty_table(summary_display, caption = "Participant-level add-points summary by condition")
correct_best <- add_points_participant_summary |>
slice_max(mean_pct_correct, n = 1, with_ties = FALSE)
correct_lowest <- add_points_participant_summary |>
slice_min(mean_pct_correct, n = 1, with_ties = FALSE)
delta_best <- add_points_participant_summary |>
slice_max(mean_intended_delta_r, n = 1, with_ties = FALSE)
slope_lowest <- add_points_participant_summary |>
slice_min(mean_abs_delta_slope, n = 1, with_ties = FALSE)
cat(
'<div class="callout"><h4>Descriptive takeaway</h4>',
'<p>The highest mean correct-direction score was in <strong>', as.character(correct_best$group),
'</strong> (', round(correct_best$mean_correct_out_of_3, 2), ' out of 3 tasks; ',
fmt_pct(correct_best$mean_pct_correct, accuracy = 0.1), '). ',
'The lowest mean correct-direction score was in <strong>', as.character(correct_lowest$group),
'</strong> (', round(correct_lowest$mean_correct_out_of_3, 2), ' out of 3 tasks; ',
fmt_pct(correct_lowest$mean_pct_correct, accuracy = 0.1), ').</p>',
'<p>The largest mean intended change in correlation was in <strong>', as.character(delta_best$group),
'</strong>. For slope preservation, lower values are better; the smallest mean absolute slope change was in <strong>',
as.character(slope_lowest$group), '</strong>.</p></div>',
sep = ""
)
