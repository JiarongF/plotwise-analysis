dataset = c(
"Add-points item-level data",
"Add-points participant-level data",
"Combined participant outcomes"
),
rows = c(
nrow(scored_add_points_item_level),
nrow(scored_add_points_participant_level),
nrow(participant_outcomes)
),
participants = c(
n_distinct(scored_add_points_item_level$participantId),
n_distinct(scored_add_points_participant_level$participantId),
