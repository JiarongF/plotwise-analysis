`slope_score_z` = "Slope prior knowledge (standardized)",
`prior_knowledge_total_z` = "Total prior knowledge (standardized)",
.default = term
),
Estimate = round(Estimate, 3),
SE = round(`Std. Error`, 3),
`Test statistic` = round(statistic, 3),
`p-value` = fmt_p(p_value)
)
},
error = function(e) {
tibble(
Term = "Fixed-effect table unavailable",
Estimate = NA_real_,
SE = NA_real_,
`Test statistic` = NA_real_,
`p-value` = conditionMessage(e)
)
}
)
out
}
model_full_results_table <- function(model, interaction_test = NULL) {
out <- model_fixed_effect_table(model) |>
rename(`Coefficient p-value` = `p-value`) |>
mutate(`Model-level p-value` = "")
if (!is.null(interaction_test) && nrow(interaction_test) > 0) {
idx <- out$Term == "PlotWise lecture × PlotWise practice"
if (any(idx)) {
out$`Model-level p-value`[idx] <- fmt_p(interaction_test$p_value[1])
}
}
out
}
clean_emm_comparison_table <- function(contrast_obj, type = NULL) {
out <- if (is.null(type)) {
as_tibble(summary(contrast_obj, infer = TRUE))
} else {
as_tibble(summary(contrast_obj, type = type, infer = TRUE))
}
estimate_col <- case_when(
"odds.ratio" %in% names(out) ~ "odds.ratio",
"ratio" %in% names(out) ~ "ratio",
"estimate" %in% names(out) ~ "estimate",
TRUE ~ NA_character_
)
lower_col <- case_when(
"asymp.LCL" %in% names(out) ~ "asymp.LCL",
"lower.CL" %in% names(out) ~ "lower.CL",
TRUE ~ NA_character_
)
upper_col <- case_when(
"asymp.UCL" %in% names(out) ~ "asymp.UCL",
"upper.CL" %in% names(out) ~ "upper.CL",
TRUE ~ NA_character_
)
stat_col <- case_when(
"z.ratio" %in% names(out) ~ "z.ratio",
"t.ratio" %in% names(out) ~ "t.ratio",
TRUE ~ NA_character_
)
out |>
mutate(
estimate_value = if (!is.na(estimate_col)) .data[[estimate_col]] else NA_real_,
lower_value = if (!is.na(lower_col)) .data[[lower_col]] else NA_real_,
upper_value = if (!is.na(upper_col)) .data[[upper_col]] else NA_real_,
statistic_value = if (!is.na(stat_col)) .data[[stat_col]] else NA_real_,
estimate_label = case_when(
estimate_col == "odds.ratio" ~ "Odds ratio",
estimate_col == "ratio" ~ "Ratio",
TRUE ~ "Difference"
)
) |>
transmute(
Contrast = contrast,
`Estimate type` = estimate_label,
Estimate = round(estimate_value, 3),
`95% CI` = ifelse(
is.na(lower_value) | is.na(upper_value),
"—",
paste0(round(lower_value, 3), " to ", round(upper_value, 3))
),
SE = round(SE, 3),
`Test statistic` = round(statistic_value, 3),
`p-value` = fmt_p_table(p.value),
p_value_numeric = p.value,
estimate_value = estimate_value,
lower_value = lower_value,
upper_value = upper_value
)
}
plot_comparison_forest <- function(comparison_table, title, subtitle = NULL, null_value = 0) {
plot_df <- comparison_table |>
filter(!is.na(estimate_value)) |>
mutate(
Contrast = fct_rev(fct_inorder(Contrast)),
significant = !is.na(p_value_numeric) & p_value_numeric < .05
)
ggplot(plot_df, aes(x = estimate_value, y = Contrast)) +
geom_vline(xintercept = null_value, linewidth = 0.5, linetype = "dashed", color = "grey55") +
geom_segment(
aes(x = lower_value, xend = upper_value, y = Contrast, yend = Contrast),
linewidth = 0.6,
color = "grey35",
na.rm = TRUE
) +
geom_point(aes(shape = significant), size = 2.7, color = "#2F2F2F") +
scale_shape_manual(values = c(`TRUE` = 16, `FALSE` = 1), guide = "none") +
labs(
title = title,
subtitle = subtitle,
x = ifelse(null_value == 1, "Odds ratio", "Estimated difference"),
y = NULL
) +
theme_minimal(base_size = 12) +
theme(
panel.grid.major.y = element_blank(),
plot.title = element_text(face = "bold"),
plot.subtitle = element_text(color = "grey35")
)
}
